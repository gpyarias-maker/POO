class Personaje:
    def __init__(self, nombre):
        self._nombre = nombre

    def atacar(self):
        print("El personaje ataca")

class Guerrero(Personaje):
    def atacar(self):
        print(f"El guerrero {self._nombre} ataca con su espada: ¡Slash!")

class Mago(Personaje):
    def atacar(self):
        print(f"El mago {self._nombre} lanza un hechizo: ¡Fuego!")

p1 = Guerrero("Ragnar")
p2 = Mago("Gandalf")

p1.atacar()
p2.atacar()
