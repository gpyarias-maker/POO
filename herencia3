class Instrumento:
    def __init__(self, nombre):
        self._nombre = nombre

    def tocar(self):
        print("El instrumento produce música")

class Guitarra(Instrumento):
    def tocar(self):
        print(f"La guitarra {self._nombre} suena: ¡Strum strum!")

class Tambor(Instrumento):
    def tocar(self):
        print(f"El tambor {self._nombre} suena: ¡Boom boom!")

g = Guitarra("Acústica")
t = Tambor("Metálico")

g.touch()
t.tocar()
